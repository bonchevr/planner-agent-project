APP_ENV=development
# Local dev: keep SQLite. Docker/production: use PostgreSQL URL below.
DATABASE_URL=sqlite:///./data/planner.db
# DATABASE_URL=postgresql://planner:planner@localhost:5432/planner
SECRET_KEY=change-me-before-deploying
BASE_URL=http://localhost:8000
# Number of Uvicorn workers (default 2). Increase for larger VMs.
WEB_WORKERS=2

# ── Email (password-reset) ─────────────────────────────────────────────────
# Leave blank to disable email; the app still works but reset links are shown
# on-screen in development mode.
# Example using Resend (https://resend.com — free tier, no credit card):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465          # 465 = SSL, 587 = STARTTLS
#   SMTP_USER=resend
#   SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
#   SMTP_FROM=Planner Agent <onboarding@resend.dev>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
